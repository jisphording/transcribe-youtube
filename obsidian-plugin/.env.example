# Primary vault — always deployed to
OBSIDIAN_PLUGINS_PATH=/path/to/your/vault/.obsidian/plugins/youtube-to-obsidian

# Additional vaults (optional) — add more as OBSIDIAN_PLUGINS_PATH_3, _4, etc.
# and mirror the deploy line in package.json for each one
# OBSIDIAN_PLUGINS_PATH_2=/path/to/second/vault/.obsidian/plugins/youtube-to-obsidian
