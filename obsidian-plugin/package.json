{
  "name": "youtube-to-obsidian",
  "version": "1.0.0",
  "description": "Import YouTube transcripts as Obsidian notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run deploy",
    "deploy": "mkdir -p \"/Users/johannes_isphoding/Documents/OBSIDIAN/WORK_NOTES/.obsidian/plugins/youtube-to-obsidian\" && cp main.js manifest.json \"/Users/johannes_isphoding/Documents/OBSIDIAN/WORK_NOTES/.obsidian/plugins/youtube-to-obsidian/\""
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
